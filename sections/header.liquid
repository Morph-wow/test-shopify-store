<header class="site-header">
  <div class="header-container">
    <div class="header__logo">
      <a href="{{ routes.root_url }}" class="logo-link">
        <span class="logo-text">LUXE ATELIER</span>
      </a>
    </div>

    <nav class="header__menu">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}" class="menu-link">{{ link.title }}</a>
      {% endfor %}
    </nav>

    <div class="header__icons">
      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}" class="icon-link">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a href="{{ routes.cart_url }}" class="icon-link cart-link">
        {% if cart.item_count > 0 %}
          <span class="cart-count">{{ cart.item_count }}</span>
        {% endif %}
        {{ 'icon-cart.svg' | inline_asset_content }}
      </a>
    </div>
  </div>
</header>

{% stylesheet %}
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
  }

  .header-container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 1.5rem var(--page-margin);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header__logo .logo-link {
    text-decoration: none;
    color: var(--color-foreground);
  }

  .logo-text {
    font-size: 1.8rem;
    font-weight: 300;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .header__menu {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  .menu-link {
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 400;
    position: relative;
    transition: color 0.3s ease;
  }

  .menu-link::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-foreground);
    transition: width 0.3s ease;
  }

  .menu-link:hover {
    color: #666;
  }

  .menu-link:hover::after {
    width: 100%;
  }

  .header__icons {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .icon-link {
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
  }

  .icon-link:hover {
    transform: translateY(-2px);
  }

  .icon-link svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .cart-count {
    position: absolute;
    top: -8px;
    right: -8px;
    background-color: var(--color-foreground);
    color: var(--color-background);
    font-size: 0.7rem;
    font-weight: 600;
    min-width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
  }

  @media (max-width: 768px) {
    .header-container {
      padding: 1rem var(--page-margin);
    }

    .logo-text {
      font-size: 1.4rem;
    }

    .header__menu {
      display: none;
    }

    .header__icons {
      gap: 1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
