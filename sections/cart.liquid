{% comment %}
  This section is used in the cart template to render /cart page with an
  overview of the items in customer's cart.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<div class="cart-page">
  <div class="cart-container">
    <h1 class="cart-title">SHOPPING CART</h1>

    {% if cart.item_count > 0 %}
      <div class="cart-content">
        <div class="cart-items">
          <form action="{{ routes.cart_url }}" method="post" id="cart-form">
            {% for item in cart.items %}
              <div class="cart-item">
                <div class="item-image">
                  <a href="{{ item.url }}">
                    {% if item.image %}
                      <img
                        src="{{ item.image | img_url: '300x300' }}"
                        alt="{{ item.image.alt | escape }}"
                        loading="lazy"
                      >
                    {% else %}
                      <div class="image-placeholder">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </a>
                </div>

                <div class="item-details">
                  <div class="item-info">
                    <h3 class="item-title">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </h3>
                    {% if item.variant.title != 'Default Title' %}
                      <p class="item-variant">{{ item.variant.title }}</p>
                    {% endif %}
                    {% if item.properties.size > 0 %}
                      {% for property in item.properties %}
                        {% unless property.last == blank %}
                          <p class="item-property">{{ property.first }}: {{ property.last }}</p>
                        {% endunless %}
                      {% endfor %}
                    {% endif %}
                  </div>

                  <div class="item-price">
                    {% if item.original_line_price > item.final_line_price %}
                      <span class="price-compare">{{ item.original_line_price | money }}</span>
                    {% endif %}
                    <span class="price">{{ item.final_line_price | money }}</span>
                  </div>
                </div>

                <div class="item-quantity">
                  <div class="quantity-selector">
                    <button type="button" class="quantity-btn" onclick="updateQuantity(this, -1, {{ forloop.index0 }})">−</button>
                    <input
                      type="number"
                      name="updates[]"
                      id="updates_{{ item.key }}"
                      value="{{ item.quantity }}"
                      min="0"
                      class="quantity-input"
                      data-index="{{ forloop.index0 }}"
                      readonly
                    >
                    <button type="button" class="quantity-btn" onclick="updateQuantity(this, 1, {{ forloop.index0 }})">+</button>
                  </div>
                  <a href="{{ item.url_to_remove }}" class="remove-item">Remove</a>
                </div>
              </div>
            {% endfor %}
          </form>
        </div>

        <div class="cart-summary">
          <h2 class="summary-title">ORDER SUMMARY</h2>

          <div class="summary-line">
            <span class="summary-label">Subtotal ({{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %})</span>
            <span class="summary-value">{{ cart.total_price | money }}</span>
          </div>

          {% if cart.cart_level_discount_applications.size > 0 %}
            <div class="summary-line discount-line">
              {% for discount in cart.cart_level_discount_applications %}
                <span class="summary-label">{{ discount.title }}</span>
                <span class="summary-value discount-value">-{{ discount.total_allocated_amount | money }}</span>
              {% endfor %}
            </div>
          {% endif %}

          <div class="summary-line summary-total">
            <span class="summary-label">Total</span>
            <span class="summary-value">{{ cart.total_price | money }}</span>
          </div>

          <p class="summary-note">Shipping & taxes calculated at checkout</p>

          <form action="{{ routes.cart_url }}" method="post">
            <button type="submit" name="checkout" class="checkout-button">
              PROCEED TO CHECKOUT
            </button>
          </form>

          <a href="/collections/all" class="continue-shopping">Continue Shopping</a>
        </div>
      </div>
    {% else %}
      <div class="cart-empty">
        <div class="empty-cart-icon">
          {{ 'icon-cart.svg' | inline_asset_content }}
        </div>
        <h2 class="empty-cart-title">Your cart is empty</h2>
        <p class="empty-cart-text">Add items to your cart to see them here.</p>
        <a href="/collections/all" class="shop-now-button">SHOP NOW</a>
      </div>
    {% endif %}
  </div>
</div>

<script>
  function updateQuantity(button, change, index) {
    const input = document.querySelectorAll('.quantity-input')[index];
    const currentValue = parseInt(input.value);
    const newValue = Math.max(0, currentValue + change);
    input.value = newValue;

    // Auto-submit form
    document.getElementById('cart-form').submit();
  }
</script>

{% stylesheet %}
  .cart-page {
    display: grid;
    grid-template-columns: var(--content-grid);
    padding: 3rem 0 6rem;
    min-height: 60vh;
  }

  .cart-container {
    grid-column: 2;
    padding: 0 24px;
  }

  .cart-title {
    font-size: 2.5rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 3rem 0;
    text-align: center;
  }

  .cart-content {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .cart-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 1.5rem;
    padding: 1.5rem;
    border: 1px solid #e5e5e5;
    transition: box-shadow 0.3s ease;
  }

  .cart-item:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .item-image {
    width: 120px;
    height: 150px;
  }

  .item-image img,
  .item-image .image-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .item-image a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .image-placeholder {
    background-color: #f6f6f7;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-placeholder svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .item-details {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .item-title {
    font-size: 1.1rem;
    font-weight: 400;
    margin: 0;
    letter-spacing: 0.02em;
  }

  .item-title a {
    text-decoration: none;
    color: var(--color-foreground);
    transition: color 0.3s ease;
  }

  .item-title a:hover {
    color: #666;
  }

  .item-variant,
  .item-property {
    font-size: 0.9rem;
    color: #666;
    margin: 0;
  }

  .item-price {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.1rem;
    margin-top: auto;
  }

  .item-price .price {
    font-weight: 500;
  }

  .item-price .price-compare {
    text-decoration: line-through;
    color: #999;
    font-size: 0.95rem;
  }

  .item-quantity {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1rem;
  }

  .quantity-selector {
    display: flex;
    align-items: center;
    border: 1px solid #ddd;
  }

  .quantity-btn {
    width: 35px;
    height: 40px;
    border: none;
    background-color: transparent;
    cursor: pointer;
    font-size: 1.1rem;
    font-weight: 300;
    transition: background-color 0.2s ease;
    color: #333;
  }

  .quantity-btn:hover {
    background-color: #f6f6f7;
  }

  .quantity-input {
    width: 50px;
    height: 40px;
    border: none;
    text-align: center;
    font-size: 0.95rem;
    font-weight: 500;
    -moz-appearance: textfield;
  }

  .quantity-input::-webkit-outer-spin-button,
  .quantity-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .quantity-input:focus {
    outline: none;
  }

  .remove-item {
    font-size: 0.85rem;
    color: #999;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.3s ease;
  }

  .remove-item:hover {
    color: #c41e3a;
  }

  .cart-summary {
    position: sticky;
    top: 120px;
    background-color: #f8f8f8;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .summary-title {
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
    padding-bottom: 1rem;
    border-bottom: 1px solid #e5e5e5;
  }

  .summary-line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.95rem;
  }

  .summary-label {
    color: #666;
  }

  .summary-value {
    font-weight: 500;
    color: #333;
  }

  .discount-line {
    color: #28a745;
  }

  .discount-value {
    color: #28a745;
  }

  .summary-total {
    padding-top: 1rem;
    border-top: 1px solid #e5e5e5;
    font-size: 1.3rem;
    font-weight: 500;
  }

  .summary-total .summary-label {
    color: #333;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .summary-note {
    font-size: 0.85rem;
    color: #666;
    text-align: center;
    margin: 0;
  }

  .checkout-button {
    width: 100%;
    padding: 1.25rem 2rem;
    background-color: var(--color-foreground);
    color: var(--color-background);
    border: 2px solid var(--color-foreground);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 1rem;
  }

  .checkout-button:hover {
    background-color: transparent;
    color: var(--color-foreground);
  }

  .continue-shopping {
    text-align: center;
    font-size: 0.9rem;
    color: #666;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.3s ease;
  }

  .continue-shopping:hover {
    color: var(--color-foreground);
  }

  .cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 2rem;
    gap: 1.5rem;
  }

  .empty-cart-icon {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .empty-cart-icon svg {
    width: 100%;
    height: 100%;
  }

  .empty-cart-title {
    font-size: 2rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0;
  }

  .empty-cart-text {
    font-size: 1rem;
    color: #666;
    margin: 0;
  }

  .shop-now-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background-color: var(--color-foreground);
    color: var(--color-background);
    text-decoration: none;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    border: 2px solid var(--color-foreground);
    margin-top: 1rem;
  }

  .shop-now-button:hover {
    background-color: transparent;
    color: var(--color-foreground);
  }

  @media (max-width: 1024px) {
    .cart-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .cart-summary {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .cart-title {
      font-size: 2rem;
    }

    .cart-item {
      grid-template-columns: 80px 1fr;
      gap: 1rem;
      padding: 1rem;
    }

    .item-image {
      width: 80px;
      height: 100px;
    }

    .item-quantity {
      grid-column: 1 / -1;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .cart-summary {
      padding: 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
